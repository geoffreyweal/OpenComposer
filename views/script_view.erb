<div class="p-3">
  <% if @script_content && !@script_content.strip.empty? %>
    <pre class="form-control p-3" style="white-space: pre-wrap; word-break: break-word; font-family: 'JetBrains Mono', monospace; min-height: 4em;"><code id="_viewScriptCode" class="language-bash"><%= escape_html(@script_content) %></code></pre>
  <% else %>
    <p class="text-muted mt-2">(No script content available for job <code><%= escape_html(@job_id) %></code>.)</p>
  <% end %>
</div>
<script>
  var el = document.getElementById('_viewScriptCode');
  if (el) hljs.highlightElement(el);
</script>
